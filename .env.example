# Environment
SUPROXY_ENVIRONMENT=development

# Server Configuration
SUPROXY_SERVER_ADDRESS=:8080
SUPROXY_SERVER_READ_TIMEOUT=10
SUPROXY_SERVER_WRITE_TIMEOUT=10
SUPROXY_SERVER_SHUTDOWN_TIMEOUT=10

# Database Configuration
SUPROXY_DATABASE_HOST=postgres
SUPROXY_DATABASE_PORT=5432
SUPROXY_DATABASE_USER=suproxy
SUPROXY_DATABASE_PASSWORD=suproxy
SUPROXY_DATABASE_DBNAME=suproxy
SUPROXY_DATABASE_SSLMODE=disable
SUPROXY_DATABASE_MAX_OPEN_CONNS=25
SUPROXY_DATABASE_MAX_IDLE_CONNS=10
SUPROXY_DATABASE_CONN_MAX_LIFETIME=5
SUPROXY_DATABASE_CONN_MAX_IDLE_TIME=10

# Log Configuration
SUPROXY_LOG_LEVEL=info
SUPROXY_LOG_FORMAT=json

# JWT Configuration
SUPROXY_JWT_SECRET_KEY=change-me-in-production-to-a-secure-random-string
SUPROXY_JWT_ACCESS_TOKEN_EXPIRY=15
SUPROXY_JWT_REFRESH_TOKEN_EXPIRY=168
SUPROXY_JWT_ISSUER=suproxy-backend
