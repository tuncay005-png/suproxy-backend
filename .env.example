# Environment
ENVIRONMENT=development

# Server Configuration
API_PORT=8080
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_SHUTDOWN_TIMEOUT=10

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=suproxy
DB_PASSWORD=suproxy
DB_NAME=suproxy
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5
DB_CONN_MAX_IDLE_TIME=10

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# JWT Configuration
JWT_SECRET=change-me-in-production-to-a-secure-random-string
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=168
JWT_ISSUER=suproxy-backend

# Xray Configuration
XRAY_USE_MOCK=true
XRAY_BINARY_PATH=/usr/local/bin/xray
XRAY_CONFIG_DIR=/etc/xray
XRAY_LOG_DIR=/var/log/xray
XRAY_BACKUP_DIR=/var/backups/xray
XRAY_INSTALL_DIR=/opt/xray

# Metrics Configuration
METRICS_ENABLED=true
METRICS_INTERVAL=30

# Docker Registry (Production)
DOCKER_REGISTRY=suproxy
VERSION=latest

# Monitoring (Production)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-in-production
